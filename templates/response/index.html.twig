<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ controller_name }}</title>
    <link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}"/>
</head>
<body>
    <div class="container mt-5">
        <h1>{{ controller_name }}</h1>
        
        <div class="card mt-4">
            <div class="card-header">
                <h5>Available Response Demos</h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Route</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Try It</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>/demo/response</code></td>
                            <td><span class="badge bg-info">HTML (Twig)</span></td>
                            <td>Rendered Twig template</td>
                            <td><a href="{{ path('demo_response') }}" class="btn btn-sm btn-primary">Open</a></td>
                        </tr>
                        <tr>
                            <td><code>/demo/response/html</code></td>
                            <td><span class="badge bg-secondary">Raw HTML</span></td>
                            <td>Direct HTML Response object</td>
                            <td><a href="{{ path('demo_response_html') }}" class="btn btn-sm btn-primary">Open</a></td>
                        </tr>
                        <tr>
                            <td><code>/demo/response/json</code></td>
                            <td><span class="badge bg-success">JSON</span></td>
                            <td>Using JsonResponse</td>
                            <td><a href="{{ path('demo_response_json') }}" class="btn btn-sm btn-primary">Open</a></td>
                        </tr>
                        <tr>
                            <td><code>/demo/response/json/short</code></td>
                            <td><span class="badge bg-success">JSON</span></td>
                            <td>Using $this->json() with cart data</td>
                            <td><a href="{{ path('demo_response_json_short') }}" class="btn btn-sm btn-primary">Open</a></td>
                        </tr>
                        <tr>
                            <td><code>/demo/response/download/{fileName}</code></td>
                            <td><span class="badge bg-warning">Binary</span></td>
                            <td>File download (BinaryFileResponse)</td>
                            <td><a href="{{ path('demo_response_download', {fileName: 'sample.pdf'}) }}" class="btn btn-sm btn-secondary">Try (needs file)</a></td>
                        </tr>
                        <tr>
                            <td><code>/demo/response/stream</code></td>
                            <td><span class="badge bg-info">Stream</span></td>
                            <td>Streamed response</td>
                            <td><a href="{{ path('demo_response_stream') }}" class="btn btn-sm btn-primary">Open</a></td>
                        </tr>
                        <tr>
                            <td><code>/demo/response/redirect</code></td>
                            <td><span class="badge bg-danger">Redirect</span></td>
                            <td>Redirect to JSON endpoint</td>
                            <td><a href="{{ path('demo_response_redirect') }}" class="btn btn-sm btn-primary">Try</a></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="card mt-4">
            <div class="card-header">
                <h5>Test with curl</h5>
            </div>
            <div class="card-body">
                <pre class="bg-dark text-light p-3 rounded"><code># JSON Response
curl http://localhost:8000/demo/response/json

# Cart JSON Response
curl http://localhost:8000/demo/response/json/short

# Redirect Response
curl -I http://localhost:8000/demo/response/redirect</code></pre>
            </div>
        </div>
    </div>
</body>
</html>
